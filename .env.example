APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5433
DB_DATABASE=mydb_st
DB_USERNAME=st_user
DB_PASSWORD=
DB_SSLMODE=prefer
# Local access to private Postgres requires an SSH tunnel, e.g.:
# ssh -i C:\ST\bastion-key.pem -N -L 5433:ip-10-103-32-100.ap-southeast-5.compute.internal:5432 ec2-user@43.217.107.131
# For local SQLite instead: DB_CONNECTION=sqlite and comment the DB_* host/user fields above.

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="Admin SISTEM DIGITAL ST"
RESEND_API_KEY=

# Optional: redirect SOS/technical/approver task emails to one inbox for demo
# (staff profile emails in the DB are not changed)
# ST_STAFF_MAIL_OVERRIDE=you@example.com

FRONTEND_URL=http://localhost:5180

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Workflow Engine (solution-forest/workflow-engine-laravel)
WORKFLOW_STORAGE_DRIVER=database
# WORKFLOW_DB_CONNECTION=  # defaults to DB_CONNECTION
WORKFLOW_DB_TABLE=workflow_instances
# WORKFLOW_FILE_PATH=  # only when WORKFLOW_STORAGE_DRIVER=file
WORKFLOW_EVENTS_ENABLED=true
WORKFLOW_ACTION_TIMEOUT=5m
WORKFLOW_ACTION_RETRY_ATTEMPTS=3
WORKFLOW_ACTION_RETRY_DELAY=30s
WORKFLOW_QUEUE_ENABLED=false
# WORKFLOW_QUEUE_CONNECTION=  # defaults to QUEUE_CONNECTION
WORKFLOW_QUEUE_NAME=workflows

# Anthropic (Condition AI + AINA User Chat)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-5
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# AINA — menu/deep links in AI answers
ST_SYSTEM_URL="${APP_URL}/admin/st"
